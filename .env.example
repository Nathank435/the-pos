# --- Site ---
# Public base URL, used for canonical URLs, sitemap and OG tags.
NEXT_PUBLIC_SITE_URL=https://thepos.co.uk

# --- Analytics (all optional; analytics no-ops if unset) ---
# Plausible: set your domain to enable the script + custom events.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# GA4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=
# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Leads ---
# Where leads go. Without any of these set, leads are written to ./.leads/*.json (dev only)
# and logged to the server console.
# Optional Supabase (server-side):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional webhook (Google Sheets / Zapier / CRM):
LEADS_WEBHOOK_URL=
# Optional email notification target (used by your email provider integration):
LEADS_NOTIFY_EMAIL=nathankeeble1@gmail.com
